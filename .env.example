CLIENT_URL=http://localhost:3000
GA_TRACKING_ID=your_Google_Analytics_tracking_id
MAIL_FROM=your_email
MAIL_HOST=your_host
MAIL_PORT=your_port
MAIL_PWD=your_password
MAIL_USER=your_username_mail
# Sanity (actualités) — https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optionnel (défaut 2024-01-01)
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Agenda Google — page Activités > cuisine partagée
#
# Option A (recommandée si vous utilisez @ericz1803/react-google-calendar) :
# 1) Activer l’API Google Calendar sur le projet : https://console.developers.google.com/flows/enableapi?apiid=calendar
# 2) Identifiants > Créer des identifiants > Clé API (ce n’est PAS le « project ID » ni le « project number »).
# 3) Restreindre la clé : restrictions d’API = Google Calendar API ; restrictions d’application = sites web (référents : localhost + domaine de prod).
# 4) Le calendrier doit être lisible publiquement (sinon les événements ne remonteront pas avec une clé navigateur).
# NEXT_PUBLIC_GOOGLE_CALENDAR_API_KEY=
# NEXT_PUBLIC_KITCHEN_CALENDAR_ID=xxxx@group.calendar.google.com
#
# Option B : iframe classique (prioritaire seulement si l’option A n’est pas configurée)
# NEXT_PUBLIC_KITCHEN_CALENDAR_EMBED_URL=https://calendar.google.com/calendar/embed?src=...&ctz=Europe%2FParis

# Espace prive pre-inscriptions 2027
PREINSCRIPTIONS_2027_PASSWORD=
PRIVATE_SESSION_SECRET=
# Destination des reponses questionnaire enseignants (defaut: x.genolhac@gmail.com)
TEACHER_QUESTIONNAIRE_TO=